generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String       @id @default(cuid())
  name         String       @unique
  createdAt    DateTime     @default(now())
  foodLogs     FoodLog[]
  foodPresets  FoodPreset[]
  stepEntries  StepEntry[]
  vitaminLogs  VitaminLog[]
  weightEntries WeightEntry[]
  whoopToken   WhoopToken?
  googleToken  GoogleToken?
  stats        UserStats?
  exercises    Exercise[]
  prEntries    PREntry[]
}

model VitaminLog {
  id     String  @id @default(cuid())
  userId String
  user   User    @relation(fields: [userId], references: [id])
  date   String
  taken  Boolean @default(false)

  @@unique([userId, date])
}

model WeightEntry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  date      String
  weightLbs Float

  @@unique([userId, date])
}

model UserStats {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  weightLbs       Float?
  heightIn        Float?   // stored as total inches; displayed as ft + in
  age             Int?
  bodyFatPct      Float?
  mode            String?  // "cutting" | "maintenance" | "bulking"
  goalRate        Float?   // lbs per week: 0.5 or 1.0
  targetWeightLbs Float?
  sleepGoalHours  Float?   // hours per night: 7.0–9.0, default 8
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

model WhoopToken {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model GoogleToken {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model StepEntry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  date      String   // "YYYY-MM-DD"
  steps     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
}

model FoodLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  date      String
  rawInput  String
  items     Json
  createdAt DateTime @default(now())
}

model Exercise {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  name      String
  type      String    // "weight_reps" | "reps" | "time" | "distance"
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  entries   PREntry[]

  @@unique([userId, name])
}

model PREntry {
  id             String   @id @default(cuid())
  exerciseId     String
  exercise       Exercise @relation(fields: [exerciseId], references: [id])
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  date           String   // "YYYY-MM-DD"
  primaryValue   Float    // weight(lbs) | reps | seconds | miles
  secondaryValue Float?   // reps when type = weight_reps
  notes          String?
  createdAt      DateTime @default(now())
}

model FoodPreset {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  name      String
  quantity  String
  calories  Int
  protein   Float
  carbs     Float
  fat       Float
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}
